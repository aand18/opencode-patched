+      for (let i = 0; i < SessionRetry.MAX_RETRIES + 5; i++) {
+        const exit = yield* Effect.exit(step(error))
+        if (Exit.isSuccess(exit)) {
+          scheduled++
+          continue
+        }
+        halted = true
+        break
+      }
