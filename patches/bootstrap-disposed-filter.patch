@@ -0,0 +1,90 @@
+/** @jsxImportSource @opentui/solid */
+import { describe, expect, test } from "bun:test"
+import { tmpdir } from "../../../fixture/fixture"
+import { mount, wait } from "./sync-fixture"
+import type { GlobalEvent } from "@opencode-ai/sdk/v2"
+
+describe("tui sync disposed filter and debounce", () => {
+  test("server.instance.disposed events are filtered and debounced", async () => {
+    await using tmp = await tmpdir()
+    await Bun.write(`${tmp.path}/kv.json`, "{}")
+    const { app, emit, project, sync, session } = await mount(undefined, tmp.path)
+
+    try {
+      const currentDir = project.instance.directory()
+      const currentWorkspace = project.workspace.current()
+      const baseline = session.length
+
+      // (a) a disposed event for a DIFFERENT directory does NOT trigger bootstrap
+      emit({
+        directory: "/tmp/different-dir",
+        project: "proj_test",
+        workspace: currentWorkspace,
+        payload: {
+          id: "evt_disposed_different",
+          type: "server.instance.disposed",
+          properties: { directory: "/tmp/different-dir" },
+        },
+      })
+
+      // Wait to verify no bootstrap is triggered
+      await Bun.sleep(400)
+      expect(session.length).toBe(baseline)
+
+      // (b) a disposed event for THIS directory DOES (after debounce)
+      emit({
+        directory: currentDir,
+        project: "proj_test",
+        workspace: currentWorkspace,
+        payload: {
+          id: "evt_disposed_this",
+          type: "server.instance.disposed",
+          properties: { directory: currentDir },
+        },
+      })
+
+      // Wait for the debounced bootstrap to run
+      await wait(() => session.length === baseline + 1)
+
+      // (c) a rapid burst coalesces into ONE bootstrap
+      const beforeBurst = session.length
+      emit({
+        directory: currentDir,
+        project: "proj_test",
+        workspace: currentWorkspace,
+        payload: {
+          id: "evt_disposed_burst1",
+          type: "server.instance.disposed",
+          properties: { directory: currentDir },
+        },
+      })
+      emit({
+        directory: currentDir,
+        project: "proj_test",
+        workspace: currentWorkspace,
+        payload: {
+          id: "evt_disposed_burst2",
+          type: "server.instance.disposed",
+          properties: { directory: currentDir },
+        },
+      })
+      emit({
+        directory: currentDir,
+        project: "proj_test",
+        workspace: currentWorkspace,
+        payload: {
+          id: "evt_disposed_burst3",
+          type: "server.instance.disposed",
+          properties: { directory: currentDir },
+        },
+      })
+
+      // Wait and verify only 1 additional bootstrap ran
+      await Bun.sleep(400)
+      expect(session.length).toBe(beforeBurst + 1)
+
+    } finally {
+      app.renderer.destroy()
+    }
+  })
+})
