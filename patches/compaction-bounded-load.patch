+
+// compaction-bounded-load.patch: the prompt loop calls filterCompactedEffect
+// every iteration; it must stop PAGING at the compaction boundary instead of
+// materializing the entire history first (a 17k-message session froze a serve
+// main loop for minutes; bead workstation-g3iy).
+describe("MessageV2.filterCompactedEffect", () => {
+  it.instance("matches eager filterCompacted without paging past the compaction boundary", () =>
+    withSession(({ sessionID }) =>
+      Effect.gen(function* () {
+        // 120 pre-compaction messages that the loop must never load
+        // (backdated: fill() defaults to Date.now()+i which would sort these
+        // AFTER the window messages under page()'s time_created ordering)
+        yield* fill(sessionID, 120, (i: number) => Date.now() - 600_000 + i)
+        // completed compaction: u1 carries the compaction part whose
+        // tail_start_id points at itself (minimal retained tail); a1 is the
+        // finished summary
+        const u1 = yield* addUser(sessionID, "compaction request")
+        yield* addAssistant(sessionID, u1, { summary: true, finish: "end_turn" })
+        yield* addCompactionPart(sessionID, u1, u1)
+        const u2 = yield* addUser(sessionID, "new question")
+        yield* addAssistant(sessionID, u2)
+
+        const eager = MessageV2.filterCompacted(yield* MessageV2.stream(sessionID))
+        let pages = 0
+        const lazy = yield* MessageV2.filterCompactedEffect(sessionID, {
+          pageSize: 10,
+          onPage: () => pages++,
+        })
+
+        expect(lazy.map((m) => m.info.id)).toEqual(eager.map((m) => m.info.id))
+        // the 4 window messages fit in the first 10-message page; the 120
+        // older messages must never be fetched
+        expect(pages).toBeGreaterThanOrEqual(1)
+        expect(pages).toBeLessThanOrEqual(2)
+      }),
+    ),
+  )
+
+  it.instance("loads full history when the session has no compaction", () =>
+    withSession(({ sessionID }) =>
+      Effect.gen(function* () {
+        const ids = yield* fill(sessionID, 25)
+        let pages = 0
+        const lazy = yield* MessageV2.filterCompactedEffect(sessionID, {
+          pageSize: 10,
+          onPage: () => pages++,
+        })
+        expect(lazy.map((m) => m.info.id)).toEqual(ids)
+        expect(pages).toBeGreaterThanOrEqual(3)
+      }),
+    ),
+  )
+})
