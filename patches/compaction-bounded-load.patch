+// compaction-bounded-load.patch: page newest-first and feed the walk
+// incrementally, stopping at the compaction boundary instead of materializing
+// the entire session history (O(window) instead of O(history) per prompt-loop
+// iteration). `pageSize`/`onPage` are test seams.
+export const filterCompactedEffect = Effect.fnUntraced(function* (
+  sessionID: SessionID,
+  options?: { pageSize?: number; onPage?: () => void },
+) {
+  const size = options?.pageSize ?? 50
+  const walk = compactedWalk()
+  let before: string | undefined
+  paging: while (true) {
+    const next = yield* page({ sessionID, limit: size, before }).pipe(
+      Effect.catchIf(NotFoundError.isInstance, () =>
+        Effect.succeed({ items: [] as WithParts[], more: false, cursor: undefined }),
+      ),
+    )
+    options?.onPage?.()
+    if (next.items.length === 0) break
+    for (let i = next.items.length - 1; i >= 0; i--) {
+      const item = next.items[i]
+      if (item && walk.feed(item)) break paging
+    }
+    if (!next.more || !next.cursor) break
+    before = next.cursor
+  }
+  return finalizeCompacted(walk.result)
 })
 
