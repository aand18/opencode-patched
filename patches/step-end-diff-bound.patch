+
+// --- Bounded step-end summary diff (upstream anomalyco/opencode#29762; bead workstation-0lik) ---
+//
+// `diffFull` builds a per-file unified diff at step-end summary time
+// (Session.summary -> computeDiff -> Snapshot.diffFull). It previously called
+// jsdiff `structuredPatch(..., { context: Number.MAX_SAFE_INTEGER })` with NO
+// upper bound. jsdiff's Myers diff is O(N*D); a full-file rewrite of a sub-2MB
+// file drives the edit distance D ~= N+M, which pins the single JS thread for
+// minutes and allocates ~1GB of path arrays while the Bun event loop is fully
+// blocked (no logs, no I/O, single core at 100% — the reported spin). The
+// summary runs via `Effect.forkIn`, but that is a cooperative fiber on the SAME
+// thread, so a synchronous jsdiff call still freezes everything.
+//
+// `boundedFilePatch` caps the work three composing ways and, when any cap trips,
+// omits the inline patch text by returning `undefined`. The optional
+// `FileDiff.patch` field is then dropped while the caller keeps the cheap
+// additions/deletions counts from `git --numstat`. Downstream consumers already
+// treat a non-string patch as "no inline diff available"
+// (packages/app/src/utils/diffs.ts guards `typeof value.patch !== "string"`;
+// the TUI renders with `when={entry.file.patch}`), so omission is safe — and
+// parser-safe, unlike a fake placeholder string which would be fed to the diff
+// parser.
+
+/**
+ * Combined `before.length + after.length` byte ceiling. Above this we skip
+ * inline diffing entirely (cheap O(1) pre-guard). With
+ * `context: Number.MAX_SAFE_INTEGER` the patch text for a large file is enormous
+ * regardless of how many lines actually changed, and the Myers cost is
+ * potentially unbounded, so a counts-only diff is the right trade-off here.
+ * Default 1 MiB: comfortably larger than ordinary edits, while a full-file
+ * rewrite of a file near the 2 MiB snapshot `limit` (combined ~4 MiB) is caught.
+ */
+export const SNAPSHOT_DIFF_MAX_BYTES = 1024 * 1024
+
+/**
+ * jsdiff Myers edit-distance ceiling. `structuredPatch` returns `undefined`
+ * once the edit length exceeds this, bounding the work for pathological
+ * many-change diffs that still slip under {@link SNAPSHOT_DIFF_MAX_BYTES}.
+ * Default 4000: generous for real edits, but caps the O(N*D) blow-up.
+ */
+export const SNAPSHOT_DIFF_MAX_EDIT_LENGTH = 4000
+
+/**
+ * jsdiff wall-clock ceiling in ms. A hard belt-and-suspenders stop so a single
+ * diff can never block the event loop for longer than this. Default 1000 ms.
+ */
+export const SNAPSHOT_DIFF_TIMEOUT_MS = 1000
+
+/**
+ * Bounded replacement for the inline step-end patch computation. Returns the
+ * unified-diff text, or `undefined` when any bound trips (caller omits the
+ * optional `patch` field and keeps counts only).
+ */
+export function boundedFilePatch(file: string, before: string, after: string): string | undefined {
+  if (before.length + after.length > SNAPSHOT_DIFF_MAX_BYTES) return undefined
+  const structured = structuredPatch(file, file, before, after, "", "", {
+    context: Number.MAX_SAFE_INTEGER,
+    maxEditLength: SNAPSHOT_DIFF_MAX_EDIT_LENGTH,
+    timeout: SNAPSHOT_DIFF_TIMEOUT_MS,
+  })
+  if (!structured) return undefined
+  return formatPatch(structured)
+}
