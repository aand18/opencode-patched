diff --git a/packages/opencode/test/snapshot/bounded-diff.test.ts b/packages/opencode/test/snapshot/bounded-diff.test.ts
new file mode 100644
index 000000000..c31ca7110
--- /dev/null
+++ b/packages/opencode/test/snapshot/bounded-diff.test.ts
@@ -0,0 +1,74 @@
+import { describe, expect, test } from "bun:test"
+import {
+  boundedFilePatch,
+  SNAPSHOT_DIFF_MAX_BYTES,
+  SNAPSHOT_DIFF_MAX_EDIT_LENGTH,
+} from "../../src/snapshot"
+
+// Regression tests for the step-end "100% CPU forever" spin
+// (upstream anomalyco/opencode#29762; bead workstation-0lik).
+//
+// Snapshot.diffFull builds a per-file unified diff at step-end summary time via
+// jsdiff `structuredPatch(..., { context: Number.MAX_SAFE_INTEGER })` with NO
+// bound. jsdiff's Myers diff is O(N*D); a full-file rewrite of a sub-2MB file
+// drives D ~= N+M, pinning the single JS thread for minutes and allocating
+// ~1GB of path arrays while the Bun event loop is blocked. `boundedFilePatch`
+// is the bounded replacement: it caps the work and, when any cap trips, omits
+// the inline patch text (returns undefined -> the optional FileDiff.patch field
+// is dropped) while the caller keeps the cheap additions/deletions counts.
+
+// Build deterministic multi-line content of roughly `targetBytes` bytes.
+const blob = (targetBytes: number, make: (i: number) => string) => {
+  const out: string[] = []
+  let size = 0
+  for (let i = 0; size < targetBytes; i++) {
+    const line = make(i)
+    out.push(line)
+    size += line.length + 1 // newline
+  }
+  return out.join("\n") + "\n"
+}
+
+describe("boundedFilePatch (#29762 / workstation-0lik)", () => {
+  test("returns a real unified patch for a small change", () => {
+    const before = "alpha\nbeta\ngamma\n"
+    const after = "alpha\nBETA\ngamma\n"
+    const patch = boundedFilePatch("f.txt", before, after)
+    expect(typeof patch).toBe("string")
+    expect(patch).toContain("-beta")
+    expect(patch).toContain("+BETA")
+  })
+
+  test("omits the patch (counts-only) when combined size exceeds the byte ceiling, without an O(N*D) spin", () => {
+    // The upstream #29762 repro shape: two ~2MB full-file-different blobs.
+    const before = blob(2_000_000, (i) => `A-${i}-${(i * 7919) % 100000}-${"x".repeat(32)}`)
+    const after = blob(2_000_000, (i) => `B-${i}-${(i * 104729) % 100003}-${"y".repeat(32)}`)
+    expect(before.length + after.length).toBeGreaterThan(SNAPSHOT_DIFF_MAX_BYTES)
+
+    const start = performance.now()
+    const patch = boundedFilePatch("foo.json", before, after)
+    const elapsed = performance.now() - start
+
+    expect(patch).toBeUndefined()
+    // Pre-guard short-circuits before jsdiff runs: must be effectively instant,
+    // never the multi-second/minute Myers explosion this fix exists to prevent.
+    expect(elapsed).toBeLessThan(500)
+  })
+
+  test("omits the patch when the edit distance exceeds maxEditLength (under the byte ceiling)", () => {
+    // Stay under the byte ceiling but force D >> maxEditLength via a full rewrite
+    // of many short lines. The bound must abort and yield counts-only.
+    const count = SNAPSHOT_DIFF_MAX_EDIT_LENGTH * 2
+    const before = Array.from({ length: count }, (_, i) => `old-${i}`).join("\n") + "\n"
+    const after = Array.from({ length: count }, (_, i) => `new-${i}`).join("\n") + "\n"
+    expect(before.length + after.length).toBeLessThan(SNAPSHOT_DIFF_MAX_BYTES)
+
+    const start = performance.now()
+    const patch = boundedFilePatch("data.txt", before, after)
+    const elapsed = performance.now() - start
+
+    expect(patch).toBeUndefined()
+    // Bounded by maxEditLength + timeout: must finish quickly, not spin.
+    expect(elapsed).toBeLessThan(2000)
+  })
+})
