+
+// Unit tests for `planRequest` itself, focused on the session.directory →
+// sessionDirectory threading that closes the multi-cwd race.
+//
+// Background: in v1.15.0 the new WorkspaceRoutingMiddleware does
+// `Session.Service.get(sessionID)` for /session/<id>/... routes, but until our
+// patch it only forwarded `session.workspaceID` into planRequest, dropping
+// `session.directory`. For sessions WITHOUT a workspace, the middleware then
+// fell through to defaultDirectory(request, url) — i.e. the x-opencode-directory
+// header — and concurrent requests to the same session from different cwds
+// bound to different per-directory Instances, bypassing the per-session busy
+// guard and producing interleaved tool_use/text in the assistant log
+// (unrecoverable Anthropic 400 "assistant message prefill" on replay).
+//
+// These tests assert the data flow that closes that race: when a session pick
+// is supplied, its `directory` field must surface as `RequestPlan.Local.sessionDirectory`,
+// while `defaultDirectory` (header/query) must continue to populate the
+// fallback `directory` for non-session-scoped routes.
+//
+// See opencode-patched/docs/plans/2026-05-15-prefill-fix-redesign-{plan,question,answer}.md
+// for the full root cause and the v1.15.0 redesign rationale.
+describe("planRequest session.directory threading", () => {
+  it.live("Local plan carries session.directory as sessionDirectory", () =>
+    Effect.gen(function* () {
+      const request = HttpServerRequest.fromWeb(
+        new Request("http://localhost/session/ses_test/prompt_async", {
+          method: "POST",
+          headers: { "x-opencode-directory": "/header-cwd" },
+        }),
+      )
+
+      const plan = yield* planRequest(request, { directory: "/session-cwd" })
+
+      expect(plan._tag).toBe("Local")
+      if (plan._tag !== "Local") return
+      // Header still populates the legacy `directory` field for back-compat
+      // (e.g. used by routes like /session create that should follow the
+      // request's cwd, not any session row).
+      expect(plan.directory).toBe("/header-cwd")
+      // The session's stored directory is now threaded through so
+      // InstanceContextMiddleware can prefer it for Instance binding.
+      expect(plan.sessionDirectory).toBe("/session-cwd")
+    }),
+  )
+
+  it.live("Local plan omits sessionDirectory when no session is supplied", () =>
+    Effect.gen(function* () {
+      const request = HttpServerRequest.fromWeb(
+        new Request("http://localhost/session?roots=true", {
+          method: "GET",
+          headers: { "x-opencode-directory": "/header-cwd" },
+        }),
+      )
+
+      const plan = yield* planRequest(request)
+
+      expect(plan._tag).toBe("Local")
+      if (plan._tag !== "Local") return
+      expect(plan.directory).toBe("/header-cwd")
+      expect(plan.sessionDirectory).toBeUndefined()
+    }),
+  )
+
+  it.live("Local plan omits sessionDirectory when session pick has no directory", () =>
+    Effect.gen(function* () {
+      const request = HttpServerRequest.fromWeb(
+        new Request("http://localhost/session/ses_test", {
+          headers: { "x-opencode-directory": "/header-cwd" },
+        }),
+      )
+
+      const plan = yield* planRequest(request, { workspaceID: undefined })
+
+      expect(plan._tag).toBe("Local")
+      if (plan._tag !== "Local") return
+      expect(plan.directory).toBe("/header-cwd")
+      expect(plan.sessionDirectory).toBeUndefined()
+    }),
+  )
+})
