diff --git a/packages/opencode/test/provider/transform.test.ts b/packages/opencode/test/provider/transform.test.ts
index c3c8cbf81..2a3cca9a7 100644
--- a/packages/opencode/test/provider/transform.test.ts
+++ b/packages/opencode/test/provider/transform.test.ts
@@ -4118,3 +4118,80 @@ describe("ProviderTransform.providerOptions - ai-gateway-provider", () => {
     expect(result).toEqual({ openaiCompatible: { reasoningEffort: "high" } })
   })
 })
+
+describe("ProviderTransform.message - gemini empty parts", () => {
+  const geminiModel = (npm = "@ai-sdk/google-vertex", providerID = "google-vertex") =>
+    ({
+      id: `${providerID}/gemini-3.5-flash`,
+      providerID,
+      api: { id: "gemini-3.5-flash", url: "https://example.com", npm },
+      name: "Gemini 3.5 Flash",
+      capabilities: {
+        temperature: true,
+        reasoning: true,
+        attachment: true,
+        toolcall: true,
+        input: { text: true, audio: false, image: true, video: false, pdf: true },
+        output: { text: true, audio: false, image: false, video: false, pdf: false },
+        interleaved: false,
+      },
+      cost: { input: 1, output: 1, cache: { read: 0, write: 0 } },
+      limit: { context: 1_000_000, output: 65_536 },
+      status: "active",
+      options: {},
+      headers: {},
+    }) as any
+
+  const summarize = (result: any[]) =>
+    result.map((m) => ({
+      role: m.role,
+      types: Array.isArray(m.content) ? m.content.map((p: any) => p.type) : "string",
+    }))
+
+  test("drops assistant messages/steps that would serialize to empty Gemini parts", () => {
+    const result = ProviderTransform.message(
+      [
+        { role: "user", content: [{ type: "text", text: "hi" }] },
+        // Empty "structural separator" step (Anthropic adaptive-thinking residue).
+        { role: "assistant", content: [{ type: "text", text: "" }] },
+        // Genuinely empty content array.
+        { role: "assistant", content: [] },
+        // Only empty reasoning + empty text.
+        {
+          role: "assistant",
+          content: [
+            { type: "reasoning", text: "" },
+            { type: "text", text: "" },
+          ],
+        },
+        // Mixed: empty text is stripped but the tool-call keeps the message alive.
+        {
+          role: "assistant",
+          content: [
+            { type: "text", text: "" },
+            { type: "tool-call", toolCallId: "c1", toolName: "bash", input: {} },
+          ],
+        },
+        { role: "assistant", content: [{ type: "text", text: "done" }] },
+      ] as any,
+      geminiModel(),
+      {},
+    )
+
+    expect(summarize(result)).toEqual([
+      { role: "user", types: ["text"] },
+      { role: "assistant", types: ["tool-call"] },
+      { role: "assistant", types: ["text"] },
+    ])
+  })
+
+  test("leaves empty assistant content untouched for non-Gemini providers", () => {
+    const result = ProviderTransform.message(
+      [{ role: "assistant", content: [{ type: "text", text: "" }] }] as any,
+      geminiModel("@ai-sdk/openai-compatible", "openai-compatible"),
+      {},
+    )
+    expect(result.length).toBe(1)
+    expect((result[0].content as any[]).length).toBe(1)
+  })
+})
